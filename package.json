{
  "name": "typograms",
  "version": "0.2.0",
  "description": "A lightweight image format (text/typogram) useful for drawing simple ASCII diagrams in technical documentation",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/typograms.mjs",
  "module": "./dist/typograms.mjs",
  "types": "./dist/typograms.d.ts",
  "exports": {
    ".": {
      "types": "./dist/typograms.d.ts",
      "import": "./dist/typograms.mjs",
      "default": "./dist/typograms.mjs"
    }
  },
  "files": [
    "dist/",
    "src/",
    "LICENSE",
    "NOTICE",
    "README.md",
    "FORK.md"
  ],
  "scripts": {
    "build": "tsup && cp dist/typograms.iife.js docs/typograms.js && cp NOTICE docs/NOTICE && cp LICENSE docs/LICENSE",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests/parity/run.spec.ts",
    "test:parity": "vitest run tests/parity/run.spec.ts",
    "test:all": "vitest run",
    "capture": "tsx scripts/parity-capture.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mab-js/typograms.git"
  },
  "keywords": [
    "ASCII",
    "diagrams",
    "SVG",
    "browsers",
    "JS"
  ],
  "author": "Matthew Burton <matthew.a.burton@gmail.com>",
  "bugs": {
    "url": "https://github.com/mab-js/typograms/issues"
  },
  "homepage": "https://mab-js.github.io/typograms",
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.8.0",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "jsdom": "^28.1.0",
    "tsup": "^8.3.5",
    "tsx": "^4.22.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}
