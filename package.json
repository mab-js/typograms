{
  "name": "typograms",
  "version": "0.1.0",
  "description": "A lightweight image format (text/typogram) useful for drawing simple ASCII diagrams in technical documentation",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/typograms.mjs",
  "module": "./dist/typograms.mjs",
  "exports": {
    ".": {
      "import": "./dist/typograms.mjs",
      "default": "./dist/typograms.mjs"
    }
  },
  "files": [
    "dist/",
    "src/",
    "LICENSE",
    "NOTICE",
    "README.md",
    "FORK.md"
  ],
  "scripts": {
    "build": "tsup && cp dist/typograms.iife.js docs/typograms.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "mocha tests",
    "test:parity": "mocha tests/parity/run.spec.js",
    "test:all": "npm run test && npm run test:parity"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/google/typograms.git"
  },
  "keywords": [
    "ASCII",
    "diagrams",
    "SVG",
    "browsers",
    "JS"
  ],
  "author": "https://sgo.to",
  "bugs": {
    "url": "https://github.com/google/typograms/issues"
  },
  "homepage": "https://github.com/google/typograms#readme",
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "jsdom": "^28.1.0",
    "mocha": "^10.2.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
